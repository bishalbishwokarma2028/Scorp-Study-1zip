{
  "version": 2,
  "buildCommand": "pnpm install && BASE_PATH=/ pnpm --filter @workspace/scorpstudy run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/scorpstudy/dist/public",
  "framework": null,
  "installCommand": "pnpm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
